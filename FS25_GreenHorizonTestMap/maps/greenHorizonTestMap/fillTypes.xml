<?xml version="1.0" encoding="utf-8"?>
<map xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://validation.gdn.giants-software.com/xml/fs25/fillTypes.xsd">
    <!-- FS25 loads map fruit types before modDesc fill types, so HEMP must
         exist here when hemp.xml is parsed. Green Horizon Industries later
         reloads this same entry with its canonical pallet properties. -->
    <fillTypes>
        <fillType
            name="HEMP"
            title="Industrial Hemp"
            showOnPriceTable="true"
            isBulkType="true"
            isPalletType="true"
            unitShort="$l10n_unit_literShort">
            <economy pricePerLiter="0.45"/>
            <physics massPerLiter="0.12"/>
        </fillType>
    </fillTypes>
</map>

         The active production recipe is currently wired inside:
         placeables/greenhouses/hempGreenhouse.xml -->

    <productionRecipes>

        <recipe id="ghi_hemp_greenhouse_basic">
            <inputs>
                <input fillType="WATER" amount="20"/>

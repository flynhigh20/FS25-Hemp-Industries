<?xml version="1.0" encoding="utf-8"?>
<modDesc descVersion="91">

    <author>TooBlastu &amp; ChatGPT</author>
    <version>0.2.17.0</version>

    <title>
        <en>Green Horizon Industries</en>
    </title>

    <description>
        <en><![CDATA[
Green Horizon Industries introduces Industrial Hemp to Farming Simulator 25.

Phase 2.17 test build: peaked glass greenhouse foundation, expanded field-hemp
crop and foliage source work, six inactive product-pallet templates, an all-product
pallet generator, and future hemp-processing recipe foundations.
        ]]></en>
    </description>

    <iconFilename>icon_mod.dds</iconFilename>
    <multiplayer supported="true"/>

    <l10n>
        <text name="storeItem_ghi_hempGreenhouse">
            <en>Hemp Greenhouse</en>
        </text>
        <text name="function_ghi_hempGreenhouse">
            <en>Grows industrial hemp using water, with an optional seeded high-yield recipe.</en>
        </text>
        <text name="production_ghi_hempGreenhouseBasic">
            <en>Grow Industrial Hemp</en>
        </text>
        <text name="production_ghi_hempGreenhouseSeeded">
            <en>Grow Seeded Industrial Hemp</en>
        </text>
    </l10n>

    <fillTypes filename="xml/fillTypes.xml"/>

    <!-- Prepared but deliberately inactive:
         xml/fruitTypes.xml
         xml/growth/hempGrowth.xml
         foliage/hemp/hempFoliagePlan.xml
         foliage/hemp/hempFieldIntegrationPlan.xml
         xml/productions/hempProcessingRecipes.xml
         pallets/xml/*.xml

         Source generators:
         tools/blender/create_hemp_foliage.py
         tools/blender/create_green_horizon_pallets.py

         Do not activate field crops, processing recipes, or custom pallets until
         their generated assets and i3d mappings have been inspected and tested. -->

    <storeItems>
        <storeItem xmlFilename="placeables/greenhouses/hempGreenhouse.xml"/>
    </storeItems>

</modDesc>

<?xml version="1.0" encoding="utf-8"?>
<modDesc descVersion="91">

    <author>TooBlastu &amp; ChatGPT</author>
    <version>0.3.0.0</version>

    <title>
        <en>Green Horizon Industries</en>
    </title>

    <description>
        <en><![CDATA[
Green Horizon Industries introduces Industrial Hemp to Farming Simulator 25.

Phase 2.18 test build: peaked glass greenhouse foundation, expanded field-hemp
foliage and map-integration planning, crop/product icon generation, cutter-effect
source generation, six product-pallet templates, and hemp-processing foundations.
        ]]></en>
    </description>

    <iconFilename>icon_mod.dds</iconFilename>
    <multiplayer supported="true"/>

    <l10n>
        <text name="storeItem_ghi_hempGreenhouse">
            <en>Hemp Greenhouse</en>
        </text>
        <text name="function_ghi_hempGreenhouse">
            <en>Grows industrial hemp using water, with an optional seeded high-yield recipe.</en>
        </text>
        <text name="production_ghi_hempGreenhouseBasic">
            <en>Grow Industrial Hemp</en>
        </text>
        <text name="production_ghi_hempGreenhouseSeeded">
            <en>Grow Seeded Industrial Hemp</en>
        </text>
        <text name="storeItem_ghi_cbdPlantSmall">
            <en>Green Horizon CBD Plant</en>
        </text>
        <text name="function_ghi_cbdPlantSmall">
            <en>Processes industrial hemp into palletized CBD oil.</en>
        </text>
        <text name="production_ghi_cbdOil">
            <en>Extract CBD Oil</en>
        </text>
        <text name="storeItem_ghi_hempProcessingFacility"><en>Green Horizon Hemp Processing Facility</en></text>
        <text name="function_ghi_hempProcessingFacility"><en>Separates industrial hemp into fiber, flower, seed, biomass, and cold-pressed hemp oil.</en></text>
        <text name="production_ghi_hempDecortication"><en>Hemp Decortication</en></text>
        <text name="production_ghi_hempFlowerSorting"><en>Hemp Flower Sorting</en></text>
        <text name="production_ghi_hempSeedCleaning"><en>Hemp Seed Cleaning</en></text>
        <text name="production_ghi_hempOilPressing"><en>Cold-Pressed Hemp Oil</en></text>
    </l10n>

    <fillTypes filename="xml/fillTypes.xml"/>

    <!-- Prepared but deliberately inactive:
         xml/fruitTypes.xml
         xml/growth/hempGrowth.xml
         foliage/hemp/hempFoliagePlan.xml
         foliage/hemp/hempFieldIntegrationPlan.xml
         foliage/hemp/hempMapRegistrationDraft.xml
         foliage/hemp/hempCutterEffectsPlan.xml
         ui/hempIconManifest.xml
         xml/productions/hempProcessingRecipes.xml
         pallets/xml/*.xml

         Source generators:
         tools/blender/create_hemp_foliage.py
         tools/blender/create_hemp_crop_icons.py
         tools/blender/create_hemp_cutter_effects.py
         tools/blender/create_green_horizon_pallets.py

         Do not activate field crops, crop icons, cutter effects, processing
         recipes, or custom pallets until their generated assets, exact FS25 XML
         keys, model nodes, and i3d mappings have been inspected and tested. -->

    <storeItems>
        <storeItem xmlFilename="placeables/greenhouses/hempGreenhouse.xml"/>
        <storeItem xmlFilename="placeables/productions/cbdPlantSmall.xml"/>
        <storeItem xmlFilename="placeables/productions/hempProcessingFacility.xml"/>
    </storeItems>

</modDesc>

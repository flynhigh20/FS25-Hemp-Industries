<?xml version="1.0" encoding="utf-8"?>
<placeable type="greenhouse" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">

    <!-- Green Horizon Industries
         Phase 2.19 active greenhouse test configuration.

         The Blender generator creates the helpers and GIANTS exports sibling
         nodes alphabetically. The mappings below match that exported order.
         Hemp plant meshes are currently part of the i3d itself. Dynamic greenhouse
         growth XML will be added after the foliage/growth assets are ready. -->

    <storeData>
        <name>$l10n_storeItem_ghi_hempGreenhouse</name>
        <functions>
            <function>$l10n_function_ghi_hempGreenhouse</function>
        </functions>
        <image>icon_mod.dds</image>
        <price>36000</price>
        <dailyUpkeep>24</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>PLACEABLE</species>
        <category>placeableMisc</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>greenhouses</tab>
        </brush>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
    </storeData>

    <base>
        <filename>placeables/greenhouses/i3d/greenHorizonHempGreenhouse.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true">
        <testAreas>
            <testArea startNode="testAreaStart01" endNode="testAreaEnd01"/>
        </testAreas>
        <sounds>
            <place template="largeImp"/>
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart01" widthNode="clearAreaWidth01" heightNode="clearAreaHeight01"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="1" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart01" widthNode="levelAreaWidth01" heightNode="levelAreaHeight01" groundType="asphalt"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorArea01Start" widthNode="indoorAreaWidth01" heightNode="indoorArea1Height"/>
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01"/>
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01"/>
        </updateAreas>
    </ai>

    <infoTrigger triggerNode="infoTrigger"/>

    <hotspots>
        <hotspot type="PRODUCTION_POINT" linkNode="unloadTriggerMarker" teleportNode="teleportNode"/>
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="warningStripes"/>
        <triggerMarker node="playerTriggerMarker" filename="$data/shared/assets/marker/markerIconWrench.i3d" adjustToGround="true"/>
        <triggerMarker node="unloadTriggerMarker" filename="$data/shared/assets/marker/markerIconWater.i3d" adjustToGround="true"/>
    </triggerMarkers>

    <greenhouse>
        <plants>
            <!-- Temporary FS25-safe growth visual for the first model test.
                 Replace this base-game visual with the custom hemp plant XML later. -->
            <plant fillType="HEMP" xmlFilename="$data/placeables/brandless/greenhouses/vegetables/lettuce/lettuce.xml"/>
        </plants>
        <plantSpaces>
            <spacesParent node="plantNodes" useRandomYRot="true"/>
        </plantSpaces>
    </greenhouse>

    <productionPoint>
        <productions>
            <production id="ghi_hemp_greenhouse_basic"
                        name="$l10n_production_ghi_hempGreenhouseBasic"
                        cyclesPerHour="20"
                        costsPerActiveHour="12">
                <inputs>
                    <input fillType="WATER" amount="20"/>
                </inputs>
                <outputs>
                    <output fillType="HEMP" amount="16" sellDirectly="true"/>
                    <output fillType="GHI_HEMP_BIOMASS" amount="4" sellDirectly="true"/>
                </outputs>
            </production>

            <production id="ghi_hemp_greenhouse_seeded"
                        name="$l10n_production_ghi_hempGreenhouseSeeded"
                        cyclesPerHour="24"
                        costsPerActiveHour="18">
                <inputs>
                    <input fillType="WATER" amount="20"/>
                    <input fillType="GHI_HEMP_SEED" amount="4"/>
                </inputs>
                <outputs>
                    <output fillType="HEMP" amount="24" sellDirectly="true"/>
                    <output fillType="GHI_HEMP_FLOWER" amount="2" sellDirectly="true"/>
                    <output fillType="GHI_HEMP_BIOMASS" amount="5" sellDirectly="true"/>
                </outputs>
            </production>
        </productions>

        <sellingStation node="sellingStation" appearsOnStats="true" supportsExtension="true">
            <unloadTrigger exactFillRootNode="exactFillRootNode"
                           fillTypes="WATER GHI_HEMP_SEED"
                           aiNode="unloadTriggerAINode"/>
        </sellingStation>

        <palletSpawner>
            <spawnPlaces>
                <spawnPlace startNode="spawnPlaceStart01" endNode="spawnPlaceEnd01"/>
            </spawnPlaces>
        </palletSpawner>

        <storage node="storage"
                 isExtension="false"
                 fillTypes="WATER GHI_HEMP_SEED HEMP GHI_HEMP_BIOMASS GHI_HEMP_FLOWER"
                 fillLevelSyncThreshold="10">
            <capacity fillType="WATER" capacity="40000"/>
            <capacity fillType="GHI_HEMP_SEED" capacity="12000"/>
            <capacity fillType="HEMP" capacity="28000"/>
            <capacity fillType="GHI_HEMP_BIOMASS" capacity="18000"/>
            <capacity fillType="GHI_HEMP_FLOWER" capacity="8000"/>
        </storage>

        <playerTrigger node="playerTrigger"/>
    </productionPoint>

    <!-- GIANTS Blender export sorts siblings alphabetically. Root child order:
         clearAreas, collisions, greenhouseGameNodes, indoorAreas, infoTrigger,
         levelAreas, testAreas, tipOcclusionUpdateAreas, visuals, warningStripes.

         Mapping syntax begins at the exported model root (0>). Therefore the
         first path component is already the root's direct child; do not add an
         extra leading |0 or FS25 walks one child too deep. -->
    <i3dMappings>
        <i3dMapping id="clearAreaStart01" node="0>0|0"/>
        <i3dMapping id="clearAreaHeight01" node="0>0|0|0"/>
        <i3dMapping id="clearAreaWidth01" node="0>0|0|1"/>

        <i3dMapping id="levelAreaStart01" node="0>5|0"/>
        <i3dMapping id="levelAreaWidth01" node="0>5|0|1"/>
        <i3dMapping id="levelAreaHeight01" node="0>5|0|0"/>

        <i3dMapping id="indoorArea01Start" node="0>3|0"/>
        <i3dMapping id="indoorAreaWidth01" node="0>3|0|1"/>
        <i3dMapping id="indoorArea1Height" node="0>3|0|0"/>

        <i3dMapping id="testAreaStart01" node="0>6|0"/>
        <i3dMapping id="testAreaEnd01" node="0>6|0|0"/>

        <i3dMapping id="tipOcclusionUpdateAreaStart01" node="0>7|0"/>
        <i3dMapping id="tipOcclusionUpdateAreaEnd01" node="0>7|0|0"/>

        <i3dMapping id="plantNodes" node="0>2|1"/>
        <i3dMapping id="palletSpawner" node="0>2|0"/>
        <i3dMapping id="spawnPlaceStart01" node="0>2|0|0"/>
        <i3dMapping id="spawnPlaceEnd01" node="0>2|0|0|0"/>

        <i3dMapping id="sellingStation" node="0>2|4"/>
        <i3dMapping id="exactFillRootNode" node="0>2|4|0"/>
        <i3dMapping id="unloadTriggerMarker" node="0>2|4|2"/>
        <i3dMapping id="unloadTriggerAINode" node="0>2|4|1"/>

        <i3dMapping id="storage" node="0>2|5"/>
        <i3dMapping id="playerTrigger" node="0>2|2"/>
        <i3dMapping id="playerTriggerMarker" node="0>2|3"/>
        <i3dMapping id="teleportNode" node="0>2|6"/>

        <i3dMapping id="infoTrigger" node="0>4"/>
        <i3dMapping id="warningStripes" node="0>9"/>
    </i3dMappings>

</placeable>

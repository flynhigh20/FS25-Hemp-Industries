<?xml version="1.0" encoding="utf-8"?>
<placeable type="productionPoint" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">

    <!-- Green Horizon Industries
         Phase 2.7 / Alpha 0.2 — hemp greenhouse production-point visibility shell.

         Keep store category as productionPoints for the productionPoint test.
         FS25 previously rejected category="greenhouses" when used on this productionPoint shell.
         The store image temporarily reuses icon_mod.dds so testing only needs one known-good image file.
         Replace this with a proper store image later. -->

    <storeData>
        <name>$l10n_storeItem_ghi_hempGreenhouse</name>
        <functions>
            <function>$l10n_function_ghi_hempGreenhouse</function>
        </functions>
        <image>icon_mod.dds</image>
        <price>36000</price>
        <dailyUpkeep>24</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>productionPoints</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>factories</tab>
        </brush>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
    </storeData>

    <base>
        <!-- Temporary local placeholder i3d for Phase 2.7 store visibility testing.
             Replace with original Green Horizon Industries i3d after Blender -> GIANTS export. -->
        <filename>placeables/greenhouses/i3d/greenHorizonHempGreenhouse.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
    </base>

    <productionPoint>
        <productions>
            <production
                id="ghi_hemp_greenhouse_basic"
                name="$l10n_production_ghi_hempGreenhouseBasic"
                cyclesPerHour="24"
                costsPerActiveHour="18">

                <inputs>
                    <input fillType="WATER" amount="20"/>
                    <input fillType="GHI_HEMP_SEED" amount="4"/>
                </inputs>

                <outputs>
                    <output fillType="HEMP" amount="18" sellDirectly="false"/>
                    <output fillType="GHI_HEMP_BIOMASS" amount="6" sellDirectly="false"/>
                </outputs>

            </production>
        </productions>
    </productionPoint>

</placeable>

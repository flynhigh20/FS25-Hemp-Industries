<?xml version="1.0" encoding="utf-8"?>
<placeable type="greenhouse" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">

    <!-- Green Horizon Industries
         Phase 2.9 — inactive draft greenhouse XML.

         This file is intentionally NOT active in modDesc.xml yet.
         It uses the FS25 greenhouse-style store values from the base glass greenhouse reference:
         species PLACEABLE, category placeableMisc, and brush tab greenhouses.

         Re-enable only after the original Green Horizon greenhouse .i3d export has matching helper nodes
         for placement, clear/level areas, triggers, storage, plant nodes, and spawn places. -->

    <storeData>
        <name>$l10n_storeItem_ghi_hempGreenhouse</name>
        <functions>
            <function>$l10n_function_ghi_hempGreenhouse</function>
        </functions>
        <image>icon_mod.dds</image>
        <price>36000</price>
        <dailyUpkeep>24</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>PLACEABLE</species>
        <category>placeableMisc</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>greenhouses</tab>
        </brush>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
    </storeData>

    <base>
        <!-- Replace with original Green Horizon Industries .i3d after Blender -> GIANTS export. -->
        <filename>placeables/greenhouses/i3d/greenHorizonHempGreenhouse.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
    </base>

    <greenhouse>
        <plants>
            <!-- Draft placeholder. Replace with our hemp plant XML after the plant node layout is exported. -->
            <plant fillType="HEMP" xmlFilename="placeables/greenhouses/plants/hemp/hemp.xml" />
        </plants>
        <plantSpaces>
            <spacesParent node="plantNodes" useRandomYRot="true" />
        </plantSpaces>
    </greenhouse>

    <productionPoint>
        <productions>
            <production
                id="ghi_hemp_greenhouse_basic"
                name="$l10n_production_ghi_hempGreenhouseBasic"
                cyclesPerHour="24"
                costsPerActiveHour="18">

                <inputs>
                    <input fillType="WATER" amount="20"/>
                </inputs>

                <outputs>
                    <output fillType="HEMP" amount="18" sellDirectly="false"/>
                </outputs>

            </production>
        </productions>

        <!-- Draft placeholders; require matching i3dMappings after export. -->
        <!--
        <sellingStation node="sellingStation" appearsOnStats="true" supportsExtension="true">
            <unloadTrigger exactFillRootNode="exactFillRootNode" fillTypes="WATER" aiNode="unloadTriggerAINode"/>
        </sellingStation>

        <loadingStation fillTypes="WATER" supportsExtension="true" />

        <palletSpawner>
            <spawnPlaces>
                <spawnPlace startNode="spawnPlaceStart01" endNode="spawnPlaceEnd01" />
            </spawnPlaces>
        </palletSpawner>

        <storage node="storage" isExtension="false" fillTypes="WATER" fillLevelSyncThreshold="10">
            <capacity fillType="WATER" capacity="40000" />
            <capacity fillType="HEMP" capacity="28000" />
        </storage>

        <playerTrigger node="playerTrigger" />
        -->
    </productionPoint>

    <!-- Add i3dMappings after the helper nodes exist in the exported .i3d. -->

</placeable>

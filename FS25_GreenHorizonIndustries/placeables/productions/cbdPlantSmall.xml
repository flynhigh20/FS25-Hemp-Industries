<?xml version="1.0" encoding="utf-8" standalone="no"?>
<placeable type="productionPoint" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_storeItem_ghi_cbdPlantSmall</name>
        <functions><function>$l10n_function_ghi_cbdPlantSmall</function></functions>
        <image>$data/placeables/brandless/productionPointsSmall/oilPlant/store_oilPlant.png</image>
        <price>68000</price>
        <dailyUpkeep>45</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>PLACEABLE</species>
        <category>productionPoints</category>
        <brush><type>placeable</type><category>production</category><tab>factories</tab></brush>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
    </storeData>
    <base>
        <filename>placeables/productions/i3d/greenhorizonhempprocessingfacility.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
    </base>
    <placement useRandomYRotation="false" useManualYRotation="true">
        <sounds><place template="smallImp"/></sounds>
    </placement>
    <clearAreas><clearArea startNode="clearAreaStart01" widthNode="clearAreaWidth01" heightNode="clearAreaHeight01"/></clearAreas>
    <leveling requireLeveling="true" maxSmoothDistance="10" maxSlope="75" maxEdgeAngle="30">
        <levelAreas><levelArea startNode="levelAreaStart01" widthNode="levelAreaWidth01" heightNode="levelAreaHeight01" groundType="asphalt"/></levelAreas>
        <paintAreas><paintArea startNode="paintAreaStart01" widthNode="paintAreaWidth01" heightNode="paintAreaHeight01" groundType="asphalt"/></paintAreas>
    </leveling>
    <indoorAreas><indoorArea startNode="indoorAreaStart01" widthNode="indoorAreaWidth01" heightNode="indoorAreaHeight01"/></indoorAreas>
    <tipOcclusionUpdateAreas><tipOcclusionUpdateArea startNode="aiUpdateAreaStart01" endNode="aiUpdateAreaEnd01"/></tipOcclusionUpdateAreas>
    <ai><updateAreas><updateArea startNode="aiUpdateAreaStart01" endNode="aiUpdateAreaEnd01"/></updateAreas></ai>
    <hotspots><hotspot type="PRODUCTION_POINT" linkNode="unloadTriggerMarker" teleportNode="playerTriggerMarker"/></hotspots>
    <triggerMarkers>
        <triggerMarker node="unloadTriggerMarker" adjustToGround="true" filename="$data/shared/assets/marker/markerIconUnload.i3d"/>
        <triggerMarker node="playerTriggerMarker" adjustToGround="true" filename="$data/shared/assets/marker/markerIconWrench.i3d"/>
    </triggerMarkers>
    <animatedObjects>
        <animatedObject saveId="personnelDoor">
            <animation duration="1.5">
                <part node="personnelDoor">
                    <keyFrame time="0" rotation="0 0 0"/>
                    <keyFrame time="1" rotation="0 100 0"/>
                </part>
            </animation>
            <controls triggerNode="personnelDoorTrigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor"/>
            <sounds>
                <moving linkNode="personnelDoor" template="glassDoorLoop"/>
                <negEnd linkNode="personnelDoor" template="metalDoorsClose"/>
                <posEnd linkNode="personnelDoor" template="metalDoorsOpen"/>
            </sounds>
        </animatedObject>
        <animatedObject saveId="rollupDoor">
            <animation duration="2.5">
                <part node="rollupDoor">
                    <keyFrame time="0" translation="-1.20804 1.75 4.11"/>
                    <keyFrame time="1" translation="-5.60804 1.75 4.11"/>
                </part>
            </animation>
            <controls triggerNode="rollupDoorTrigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor"/>
        </animatedObject>
    </animatedObjects>
    <productionPoint>
        <productions>
            <production id="ghi_cbd_oil_hemp" name="$l10n_production_ghi_cbdOilHemp" cyclesPerHour="4" costsPerActiveHour="32">
                <inputs><input fillType="HEMP" amount="40"/></inputs>
                <outputs><output fillType="GHI_CBD_OIL" amount="10"/></outputs>
            </production>
            <production id="ghi_cbd_oil_flower" name="$l10n_production_ghi_cbdOilFlower" cyclesPerHour="4" costsPerActiveHour="32">
                <inputs><input fillType="HEMP_FLOWER" amount="20"/></inputs>
                <outputs><output fillType="GHI_CBD_OIL" amount="10"/></outputs>
            </production>
        </productions>
        <storage isExtension="false" fillLevelSyncThreshold="50">
            <capacity fillType="HEMP" capacity="48000"/>
            <capacity fillType="HEMP_FLOWER" capacity="24000"/>
            <capacity fillType="GHI_CBD_OIL" capacity="12000"/>
        </storage>
        <sellingStation node="sellingStation" supportsExtension="false" allowMissions="false">
            <unloadTrigger exactFillRootNode="unloadTrigger" fillTypes="HEMP HEMP_FLOWER"/>
        </sellingStation>
        <palletSpawner><spawnPlaces><spawnPlace startNode="palletAreaStart01" endNode="palletAreaEnd01"/></spawnPlaces></palletSpawner>
        <playerTrigger node="playerTrigger"/>
        <sounds>
            <idle template="placeableSmallIdleGeneric" linkNode="0>"/>
            <active template="dairyWork" linkNode="0>" pitchScale="1.2" innerRadius="2" outerRadius="15" volumeScale="0.9"/>
        </sounds>
    </productionPoint>
    <i3dMappings>
        <i3dMapping id="sellingStation" node="0>1"/>
        <i3dMapping id="aiUpdateAreaEnd01" node="0>1|0"/>
        <i3dMapping id="aiUpdateAreaStart01" node="0>1|1"/>
        <i3dMapping id="clearAreaHeight01" node="0>1|2"/>
        <i3dMapping id="clearAreaStart01" node="0>1|3"/>
        <i3dMapping id="clearAreaWidth01" node="0>1|4"/>
        <i3dMapping id="indoorAreaHeight01" node="0>1|5"/>
        <i3dMapping id="indoorAreaStart01" node="0>1|6"/>
        <i3dMapping id="indoorAreaWidth01" node="0>1|7"/>
        <i3dMapping id="levelAreaHeight01" node="0>1|8"/>
        <i3dMapping id="levelAreaStart01" node="0>1|9"/>
        <i3dMapping id="levelAreaWidth01" node="0>1|10"/>
        <i3dMapping id="paintAreaHeight01" node="0>1|11"/>
        <i3dMapping id="paintAreaStart01" node="0>1|12"/>
        <i3dMapping id="paintAreaWidth01" node="0>1|13"/>
        <i3dMapping id="palletSpawner" node="0>1|14"/>
        <i3dMapping id="palletAreaStart01" node="0>1|14|0"/>
        <i3dMapping id="palletAreaEnd01" node="0>1|14|0|0"/>
        <i3dMapping id="personnelDoorTrigger" node="0>1|15"/>
        <i3dMapping id="playerTrigger" node="0>1|16"/>
        <i3dMapping id="playerTriggerMarker" node="0>1|17"/>
        <i3dMapping id="rollupDoorTrigger" node="0>1|18"/>
        <i3dMapping id="unloadTrigger" node="0>1|21"/>
        <i3dMapping id="unloadTriggerMarker" node="0>1|22"/>
        <i3dMapping id="personnelDoor" node="0>2|160"/>
        <i3dMapping id="rollupDoor" node="0>2|170"/>
    </i3dMappings>
</placeable>

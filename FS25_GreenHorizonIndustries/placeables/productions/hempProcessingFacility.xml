<?xml version="1.0" encoding="utf-8" standalone="no"?>
<placeable type="productionPoint" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_storeItem_ghi_hempProcessingFacility</name>
        <functions><function>$l10n_function_ghi_hempProcessingFacility</function></functions>
        <image>placeables/productions/store_hempProcessingFacility.png</image>
        <price>125000</price>
        <dailyUpkeep>85</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>PLACEABLE</species>
        <category>productionPoints</category>
        <brush><type>placeable</type><category>production</category><tab>factories</tab></brush>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
    </storeData>

    <base>
        <filename>placeables/productions/i3d/greenHorizonHempProcessingFacility.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true">
        <sounds><place template="largeImp"/></sounds>
    </placement>

    <hotspots>
        <hotspot type="PRODUCTION_POINT" linkNode="unloadTriggerMarker" teleportNode="playerTriggerMarker"/>
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="unloadTriggerMarker" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="true"/>
        <triggerMarker node="playerTriggerMarker" filename="$data/shared/assets/marker/markerIconWrench.i3d" adjustToGround="true"/>
        <triggerMarker node="palletSpawner" filename="$data/shared/assets/marker/markerIconPallet.i3d" adjustToGround="true"/>
        <triggerMarker node="palletSpawner" filename="placeables/shared/palletWarningStripes.i3d"/>
    </triggerMarkers>

    <productionPoint>
        <productions sharedThroughputCapacity="false">
            <production id="ghi_hemp_decortication" name="$l10n_production_ghi_hempDecortication" cyclesPerHour="12" costsPerActiveHour="42">
                <inputs><input fillType="HEMP" amount="100"/></inputs>
                <outputs>
                    <output fillType="GHI_HEMP_FIBER" amount="45"/>
                    <output fillType="GHI_HEMP_BIOMASS" amount="45"/>
                </outputs>
            </production>
            <production id="ghi_hemp_flower_sorting" name="$l10n_production_ghi_hempFlowerSorting" cyclesPerHour="8" costsPerActiveHour="55">
                <inputs><input fillType="HEMP" amount="100"/></inputs>
                <outputs>
                    <output fillType="GHI_HEMP_FLOWER" amount="18"/>
                    <output fillType="GHI_HEMP_BIOMASS" amount="70"/>
                </outputs>
            </production>
        </productions>

        <storage isExtension="false" fillLevelSyncThreshold="50">
            <capacity fillType="HEMP" capacity="120000"/>
            <capacity fillType="GHI_HEMP_BIOMASS" capacity="90000"/>
            <capacity fillType="GHI_HEMP_FIBER" capacity="50000"/>
            <capacity fillType="GHI_HEMP_FLOWER" capacity="30000"/>
        </storage>

        <sellingStation node="sellingStation" supportsExtension="false" allowMissions="false">
            <unloadTrigger exactFillRootNode="unloadTrigger" fillTypes="HEMP"/>
        </sellingStation>

        <palletSpawner>
            <spawnPlaces><spawnPlace startNode="palletAreaStart" endNode="palletAreaEnd"/></spawnPlaces>
        </palletSpawner>

        <playerTrigger node="playerTrigger"/>
    </productionPoint>

    <animatedObjects>
        <animatedObject saveId="personnelDoor">
            <animation duration="1.5">
                <part node="personnelDoor"><keyFrame time="0" translation="0 0 0"/><keyFrame time="1" translation="-1.35 0 0"/></part>
                <part node="personnelDoorWindow"><keyFrame time="0" translation="0 0 0"/><keyFrame time="1" translation="-1.35 0 0"/></part>
                <part node="collisionPersonnelDoor"><keyFrame time="0" translation="0 0 0"/><keyFrame time="1" translation="-1.35 0 0"/></part>
            </animation>
            <controls triggerNode="personnelDoorTrigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor"/>
            <sounds>
                <moving linkNode="personnelDoor" template="glassDoorLoop"/>
                <negEnd linkNode="personnelDoor" template="metalDoorsClose"/>
                <posEnd linkNode="personnelDoor" template="metalDoorsOpen"/>
            </sounds>
        </animatedObject>
        <animatedObject saveId="rollupDoor">
            <animation duration="2.5">
                <part node="rollupDoor"><keyFrame time="0" translation="0 0 0"/><keyFrame time="1" translation="0 3.55 0"/></part>
                <part node="rollupRib01"><keyFrame time="0" translation="0 0 0"/><keyFrame time="1" translation="0 3.55 0"/></part>
                <part node="rollupRib02"><keyFrame time="0" translation="0 0 0"/><keyFrame time="1" translation="0 3.55 0"/></part>
                <part node="rollupRib03"><keyFrame time="0" translation="0 0 0"/><keyFrame time="1" translation="0 3.55 0"/></part>
                <part node="rollupRib04"><keyFrame time="0" translation="0 0 0"/><keyFrame time="1" translation="0 3.55 0"/></part>
                <part node="rollupRib05"><keyFrame time="0" translation="0 0 0"/><keyFrame time="1" translation="0 3.55 0"/></part>
                <part node="rollupRib06"><keyFrame time="0" translation="0 0 0"/><keyFrame time="1" translation="0 3.55 0"/></part>
                <part node="collisionRollupDoor"><keyFrame time="0" translation="0 0 0"/><keyFrame time="1" translation="0 3.55 0"/></part>
            </animation>
            <controls triggerNode="rollupDoorTrigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor"/>
            <sounds>
                <moving linkNode="rollupDoor" template="metalDoorsLoop"/>
                <negEnd linkNode="rollupDoor" template="metalDoorsClose"/>
                <posEnd linkNode="rollupDoor" template="metalDoorsOpen"/>
            </sounds>
        </animatedObject>
    </animatedObjects>

    <i3dMappings>
        <i3dMapping id="palletAreaEnd" node="0>1|0"/>
        <i3dMapping id="palletAreaStart" node="0>1|1"/>
        <i3dMapping id="palletSpawner" node="0>1|2"/>
        <i3dMapping id="personnelDoorTrigger" node="0>1|3"/>
        <i3dMapping id="playerTrigger" node="0>1|4"/>
        <i3dMapping id="playerTriggerMarker" node="0>1|5"/>
        <i3dMapping id="rollupDoorTrigger" node="0>1|6"/>
        <i3dMapping id="sellingStation" node="0>1"/>
        <i3dMapping id="unloadTrigger" node="0>1|7"/>
        <i3dMapping id="unloadTriggerMarker" node="0>1|8"/>
        <i3dMapping id="collisionPersonnelDoor" node="0>0|3"/>
        <i3dMapping id="collisionRollupDoor" node="0>0|6"/>
        <i3dMapping id="personnelDoor" node="0>2|17"/>
        <i3dMapping id="personnelDoorWindow" node="0>2|18"/>
        <i3dMapping id="rollupDoor" node="0>2|28"/>
        <i3dMapping id="rollupRib01" node="0>2|29"/>
        <i3dMapping id="rollupRib02" node="0>2|30"/>
        <i3dMapping id="rollupRib03" node="0>2|31"/>
        <i3dMapping id="rollupRib04" node="0>2|32"/>
        <i3dMapping id="rollupRib05" node="0>2|33"/>
        <i3dMapping id="rollupRib06" node="0>2|34"/>
    </i3dMappings>
</placeable>
